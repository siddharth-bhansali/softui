      <p style="font-size:12px;color:var(--sui-text-muted);margin-bottom:8px;text-align:center;">12-hour</p>
      <div class="sui-timepicker" data-sui-timepicker></div>
    </div>
    <div>
      <p style="font-size:12px;color:var(--sui-text-muted);margin-bottom:8px;text-align:center;">24-hour</p>
      <div class="sui-timepicker" data-sui-timepicker="24h"></div>
    </div>
  </div>
