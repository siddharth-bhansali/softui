<!-- Default (Right) -->
<div class="pg-section" id="section-1">
  <h3 class="pg-section-title">Default (Right)</h3>
  <div class="pg-section-row">
    <button class="sui-btn sui-btn-primary" onclick="SoftUI.sheet('#demoSheet').open()">Open Sheet</button>
  </div>
  <div class="pg-code-wrap">
    <button class="pg-code-toggle" onclick="toggleGalleryCode(this)"><span class="chevron">&#9654;</span> Show Code</button>
    <div class="pg-code-block"><button class="pg-code-copy" onclick="copyPgCode(this)">Copy</button><pre>&lt;div class="sui-sheet-backdrop" id="mySheet" role="dialog" aria-modal="true"&gt;
  &lt;div class="sui-sheet sui-sheet-right"&gt;
    &lt;div class="sui-sheet-header"&gt;
      &lt;h3&gt;Sheet Title&lt;/h3&gt;
      &lt;button class="sui-sheet-close" aria-label="Close"&gt;&lt;/button&gt;
    &lt;/div&gt;
    &lt;div class="sui-sheet-body"&gt;
      &lt;p&gt;Sheet content here.&lt;/p&gt;
    &lt;/div&gt;
    &lt;div class="sui-sheet-footer"&gt;
      &lt;button class="sui-btn sui-btn-sm" onclick="SoftUI.sheet('#mySheet').close()"&gt;Cancel&lt;/button&gt;
      &lt;button class="sui-btn sui-btn-primary sui-btn-sm"&gt;Save&lt;/button&gt;
    &lt;/div&gt;
  &lt;/div&gt;
&lt;/div&gt;

&lt;script&gt;
  SoftUI.sheet('#mySheet').open();
  SoftUI.sheet('#mySheet').close();
&lt;/script&gt;</pre></div>
  </div>
</div>

