<!-- Single Select -->
<div class="pg-section" id="section-1">
  <h3 class="pg-section-title">Single Select</h3>
  <p style="font-size:13px;color:var(--sui-text-light);margin-bottom:16px;">Only one item can be active at a time. Click an active item to deselect it.</p>
  <div class="pg-section-row">
    <div class="sui-toggle-group" data-sui-toggle="single">
      <button class="sui-toggle-group-item active" aria-pressed="true">Left</button>
      <button class="sui-toggle-group-item" aria-pressed="false">Center</button>
      <button class="sui-toggle-group-item" aria-pressed="false">Right</button>
    </div>
  </div>
  <div class="pg-code-wrap">
    <button class="pg-code-toggle" onclick="toggleGalleryCode(this)"><span class="chevron">&#9654;</span> Show Code</button>
    <div class="pg-code-block"><button class="pg-code-copy" onclick="copyPgCode(this)">Copy</button><pre>&lt;div class="sui-toggle-group" data-sui-toggle="single"&gt;
  &lt;button class="sui-toggle-group-item active" aria-pressed="true"&gt;Left&lt;/button&gt;
  &lt;button class="sui-toggle-group-item" aria-pressed="false"&gt;Center&lt;/button&gt;
  &lt;button class="sui-toggle-group-item" aria-pressed="false"&gt;Right&lt;/button&gt;
&lt;/div&gt;</pre></div>
  </div>
</div>

