<div class="pg-section" id="section-7">
  <h3 class="pg-section-title">Alert Dialog</h3>
  <p style="font-size:13px;color:var(--sui-text-light);margin-bottom:16px;">A confirmation dialog that requires explicit user action. Combines <code>sui-modal-sm</code> + <code>sui-modal-static</code> with no close button and <code>role="alertdialog"</code>. Clicking outside shakes the dialog instead of dismissing it — the user must choose an action.</p>
  <div class="pg-section-row">
    <button class="sui-btn sui-btn-danger" onclick="SoftUI.modal('#demoModalAlert').open()">Delete Item</button>
  </div>
  <div class="pg-code-wrap">
    <button class="pg-code-toggle" onclick="toggleGalleryCode(this)"><span class="chevron">&#9654;</span> Show Code</button>
    <div class="pg-code-block"><button class="pg-code-copy" onclick="copyPgCode(this)">Copy</button><pre>&lt;!-- Alert Dialog = sui-modal-sm + sui-modal-static + no close button --&gt;
&lt;div class="sui-modal-backdrop sui-modal-static" id="alertDialog"
     role="alertdialog" aria-modal="true"
     aria-labelledby="alertTitle" aria-describedby="alertDesc"&gt;
  &lt;div class="sui-modal sui-modal-sm"&gt;
    &lt;div class="sui-modal-header"&gt;
      &lt;h3 id="alertTitle"&gt;Delete this item?&lt;/h3&gt;
    &lt;/div&gt;
    &lt;div class="sui-modal-body"&gt;
      &lt;p id="alertDesc"&gt;This action cannot be undone. This will permanently
      delete the item and remove all associated data.&lt;/p&gt;
    &lt;/div&gt;
    &lt;div class="sui-modal-footer"&gt;
      &lt;button class="sui-btn sui-btn-sm"
        onclick="SoftUI.modal('#alertDialog').close()"&gt;Cancel&lt;/button&gt;
      &lt;button class="sui-btn sui-btn-danger sui-btn-sm"&gt;Delete&lt;/button&gt;
    &lt;/div&gt;
  &lt;/div&gt;
&lt;/div&gt;</pre></div>
  </div>
</div>
