<!-- Default -->
<div class="pg-section" id="section-1">
  <h3 class="pg-section-title">Default</h3>
  <div class="pg-section-row">
    <div class="sui-btn-group">
      <button class="sui-btn">Left</button>
      <button class="sui-btn active">Center</button>
      <button class="sui-btn">Right</button>
    </div>
  </div>
  <div class="pg-code-wrap">
    <button class="pg-code-toggle" onclick="toggleGalleryCode(this)"><span class="chevron">&#9654;</span> Show Code</button>
    <div class="pg-code-block"><button class="pg-code-copy" onclick="copyPgCode(this)">Copy</button><pre>&lt;div class="sui-btn-group"&gt;
  &lt;button class="sui-btn"&gt;Left&lt;/button&gt;
  &lt;button class="sui-btn active"&gt;Center&lt;/button&gt;
  &lt;button class="sui-btn"&gt;Right&lt;/button&gt;
&lt;/div&gt;</pre></div>
  </div>
</div>

