  <div class="pg-section-row">
    <div style="display:flex;flex-direction:column;gap:12px;max-width:400px;">
      <div class="sui-copy">
        <span class="sui-copy-text">npm install softui-css</span>
        <button class="sui-copy-btn" data-sui-copy>{{ clipSvg | safe }}</button>
      </div>
      <div class="sui-copy">
        <span class="sui-copy-text">https://softui-css.netlify.app</span>
        <button class="sui-copy-btn" data-sui-copy>{{ clipSvg | safe }}</button>
      </div>
      <div class="sui-copy">
        <span class="sui-copy-text">sk-1234-abcd-5678-efgh-9012</span>
        <button class="sui-copy-btn" data-sui-copy>{{ clipSvg | safe }}</button>
      </div>
    </div>
  </div>
  <div class="pg-code-wrap">
    <button class="pg-code-toggle" onclick="toggleGalleryCode(this)"><span class="chevron">&#9654;</span> Show Code</button>
    <div class="pg-code-block"><button class="pg-code-copy" onclick="copyPgCode(this)">Copy</button><pre>&lt;div class="sui-copy"&gt;
  &lt;span class="sui-copy-text"&gt;npm install softui-css&lt;/span&gt;
  &lt;button class="sui-copy-btn" data-sui-copy&gt;
    &lt;svg viewBox="0 0 24 24"&gt;&lt;rect x="9" y="9" width="13" height="13" rx="2" ry="2"/&gt;&lt;path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/&gt;&lt;/svg&gt;
  &lt;/button&gt;
&lt;/div&gt;

&lt;!-- Click the button — icon swaps to checkmark for 1.5s --&gt;
&lt;!-- Text is auto-read from .sui-copy-text sibling --&gt;</pre></div>
  </div>
</div>

<!-- Inline -->
<div class="pg-section" id="section-2">
  <h3 class="pg-section-title">Inline</h3>
  <div class="pg-section-row">
    <div style="display:flex;flex-wrap:wrap;gap:24px;align-items:center;">
      <div style="display:flex;align-items:center;gap:6px;">
        <code style="font-size:13px;">sk-1234-abcd-5678</code>
        <button class="sui-copy-inline" data-sui-copy="sk-1234-abcd-5678">{{ clipSvg | safe }}</button>
      </div>
      <div style="display:flex;align-items:center;gap:6px;">
        <span style="font-size:13px;">Invite code: <strong>SOFTUI2026</strong></span>
        <button class="sui-copy-inline" data-sui-copy="SOFTUI2026">{{ clipSvg | safe }}</button>
      </div>
    </div>
  </div>
  <div class="pg-code-wrap">
    <button class="pg-code-toggle" onclick="toggleGalleryCode(this)"><span class="chevron">&#9654;</span> Show Code</button>
    <div class="pg-code-block"><button class="pg-code-copy" onclick="copyPgCode(this)">Copy</button><pre>&lt;!-- Inline — just the icon, pass text via data-sui-copy --&gt;
&lt;code&gt;sk-1234-abcd-5678&lt;/code&gt;
&lt;button class="sui-copy-inline" data-sui-copy="sk-1234-abcd-5678"&gt;
  &lt;svg viewBox="0 0 24 24"&gt;&lt;rect x="9" y="9" width="13" height="13" rx="2" ry="2"/&gt;&lt;path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/&gt;&lt;/svg&gt;
&lt;/button&gt;

&lt;!-- data-sui-copy="text" copies that exact string --&gt;
&lt;!-- Without data-sui-copy value, reads from .sui-copy-text sibling --&gt;</pre></div>
  </div>
</div>

