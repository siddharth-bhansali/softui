    <div class="sui-resizable" style="height:200px;">
      <div class="sui-resizable-panel" data-size="30" data-min-size="15" style="display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:600;color:var(--sui-text-muted);">Sidebar (min 15)</div>
