<!-- Section 4 — Drop Zone -->
<div class="pg-section" id="section-4">
  <h3 class="pg-section-title">Drop Zone</h3>
  <p class="pg-section-desc">A file upload area that highlights when files are dragged over it. Dropped files appear as a list below.</p>

  <div class="pg-section-row" style="max-width:480px;">
    <div class="sui-dropzone">
      <svg class="sui-dropzone-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
        <polyline points="17 8 12 3 7 8"/>
        <line x1="12" y1="3" x2="12" y2="15"/>
      </svg>
      <div class="sui-dropzone-text"><strong>Click to upload</strong> or drag and drop</div>
