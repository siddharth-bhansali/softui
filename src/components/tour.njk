        <span class="sui-badge sui-badge-primary" id="tour2-badge">3 new</span>
        <span class="sui-badge sui-badge-success" id="tour2-badge2">Online</span>
      </div>
      <div class="sui-card" style="padding:16px;" id="tour2-card">
        <h4 style="font-size:14px;margin-bottom:6px;">Notifications</h4>
        <p style="font-size:12px;color:var(--sui-text-muted);">You have 3 unread notifications.</p>
      </div>
      <button class="sui-btn sui-btn-primary" onclick="startDemoTour2()">Start Tour (No Overlay)</button>
