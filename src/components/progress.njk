<script>
document.addEventListener('DOMContentLoaded', function() {
  const config = {
    defaults: { color: 'Primary', size: 'Default', fill: 65, indeterminate: false },
    controls: [
      { key: 'color', label: 'Color', type: 'radio', options: ['Primary', 'Success', 'Danger', 'Warning', 'Info'] },
      { key: 'size', label: 'Size', type: 'radio', options: ['Small', 'Default', 'Large'] },
      { key: 'fill', label: 'Fill', type: 'range', min: 0, max: 100, unit: '%' },
      { key: 'indeterminate', label: 'Indeterminate', type: 'toggle' },
    ],
    render(opts) {
      let outerCls = 'sui-progress';
      if (opts.size === 'Small') outerCls += ' sui-progress-sm';
      else if (opts.size === 'Large') outerCls += ' sui-progress-lg';
      if (opts.indeterminate) outerCls += ' sui-progress-indeterminate';
      const barCls = 'sui-progress-bar sui-progress-' + opts.color.toLowerCase();
      const widthStyle = opts.indeterminate ? '' : ' style="width:' + opts.fill + '%;"';
      return '<div class="' + outerCls + '">\n  <div class="' + barCls + '"' + widthStyle + '></div>\n</div>';
    }
  };

  function renderControls() {
    let html = '<div class="pg-controls-title">Customize</div>';
    config.controls.forEach(ctrl => {
      if (ctrl.type === 'radio') {
        html += '<div class="pg-control-group"><label class="pg-control-label">' + ctrl.label + '</label>';
        ctrl.options.forEach(opt => {
          const checked = opt === config.defaults[ctrl.key] ? ' checked' : '';
          html += '<label class="sui-radio"><input type="radio" name="ctrl-' + ctrl.key + '" value="' + opt + '"' + checked + ' onchange="updatePreview()"><span class="sui-radio-mark"></span>' + opt + '</label>';
        });
        html += '</div>';
      } else if (ctrl.type === 'range') {
        html += '<div class="pg-control-group"><label class="pg-control-label">' + ctrl.label + ' <span id="rangeVal-' + ctrl.key + '">' + config.defaults[ctrl.key] + ctrl.unit + '</span></label>';
        html += '<input type="range" min="' + ctrl.min + '" max="' + ctrl.max + '" value="' + config.defaults[ctrl.key] + '" data-control="' + ctrl.key + '" data-unit="' + ctrl.unit + '" oninput="document.getElementById(\'rangeVal-' + ctrl.key + '\').textContent=this.value+\'' + ctrl.unit + '\';updatePreview();" style="width:100%;">';
        html += '</div>';
      } else if (ctrl.type === 'toggle') {
        const checked = config.defaults[ctrl.key] ? ' checked' : '';
        html += '<div class="pg-control-group"><div class="pg-control-row"><label class="pg-control-label">' + ctrl.label + '</label><label class="sui-toggle sui-toggle-sm sui-toggle-primary"><input type="checkbox" data-control="' + ctrl.key + '"' + checked + ' onchange="updatePreview()"><span class="sui-toggle-slider"></span></label></div></div>';
      }
    });
    document.getElementById('pgControlsContent').innerHTML = html;
  }

  window.updatePreview = function() {
    const opts = {};
    config.controls.forEach(ctrl => {
      if (ctrl.type === 'radio') {
        const el = document.querySelector('input[name="ctrl-' + ctrl.key + '"]:checked');
        opts[ctrl.key] = el ? el.value : config.defaults[ctrl.key];
      } else if (ctrl.type === 'range') {
        const el = document.querySelector('[data-control="' + ctrl.key + '"]');
        opts[ctrl.key] = el ? parseInt(el.value, 10) : config.defaults[ctrl.key];
      } else if (ctrl.type === 'toggle') {
        const el = document.querySelector('[data-control="' + ctrl.key + '"]');
        opts[ctrl.key] = el ? el.checked : config.defaults[ctrl.key];
      }
    });
    const code = config.render(opts);
    document.getElementById('pgPreview').innerHTML = code;
    document.getElementById('pgCode').textContent = code;
  };

  renderControls();
  updatePreview();
});
</script>
