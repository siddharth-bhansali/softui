  "linear-gradient(135deg, var(--sui-info), var(--sui-success))",
  "linear-gradient(135deg, var(--sui-success), var(--sui-warning))",
  "linear-gradient(135deg, var(--sui-warning), var(--sui-danger))",
  "linear-gradient(135deg, var(--sui-danger), var(--sui-primary))",
  "linear-gradient(135deg, var(--sui-primary), var(--sui-success))"
] %}

<!-- Default -->
