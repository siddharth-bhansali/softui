<!-- Default -->
<div class="pg-section" id="section-1">
  <h3 class="pg-section-title">Default</h3>
  <div class="pg-section-row">
    <div class="sui-diff" data-sui-diff style="max-width:500px;">
      <img class="sui-diff-before" src="{{ imgBefore }}" alt="Before">
      <img class="sui-diff-after" src="{{ imgAfter }}" alt="After">
      <div class="sui-diff-handle"><div class="sui-diff-handle-arrows"><svg viewBox="0 0 6 10"><path d="M6 0L0 5l6 5z"/></svg><svg viewBox="0 0 6 10"><path d="M0 0l6 5-6 5z"/></svg></div></div>
    </div>
  </div>
  <div class="pg-code-wrap">
    <button class="pg-code-toggle" onclick="toggleGalleryCode(this)"><span class="chevron">&#9654;</span> Show Code</button>
    <div class="pg-code-block"><button class="pg-code-copy" onclick="copyPgCode(this)">Copy</button><pre>&lt;div class="sui-diff" data-sui-diff&gt;
  &lt;img class="sui-diff-before" src="before.jpg" alt="Before"&gt;
  &lt;img class="sui-diff-after" src="after.jpg" alt="After"&gt;
  &lt;div class="sui-diff-handle"&gt;&lt;div class="sui-diff-handle-arrows"&gt;&lt;svg viewBox="0 0 6 10"&gt;&lt;path d="M6 0L0 5l6 5z"/&gt;&lt;/svg&gt;&lt;svg viewBox="0 0 6 10"&gt;&lt;path d="M0 0l6 5-6 5z"/&gt;&lt;/svg&gt;&lt;/div&gt;&lt;/div&gt;
&lt;/div&gt;

&lt;!-- Drag the handle left/right to compare --&gt;
&lt;!-- Touch supported on mobile --&gt;</pre></div>
  </div>
</div>

