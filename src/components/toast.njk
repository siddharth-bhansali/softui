---
layout: component.njk
title: Toast
description: Auto-dismissing slide-in notifications with stacking and color variants.
componentId: toast
hasControls: false
requiresJs: true
toc:
  - Default
  - Variants
  - Positions
---

<!-- Default -->
<div class="pg-section" id="section-1">
  <h3 class="pg-section-title">Default</h3>
  <div class="pg-section-row" style="gap:12px;">
    <button class="sui-btn sui-btn-primary" onclick="SoftUI.toast({ title: 'Notification', message: 'This is a default toast message.' })">Show Toast</button>
    <button class="sui-btn" onclick="SoftUI.toast({ title: 'No auto-close', message: 'This toast stays until you dismiss it.', duration: 0 })">Persistent Toast</button>
  </div>
  <div class="pg-code-wrap">
    <button class="pg-code-toggle" onclick="toggleGalleryCode(this)"><span class="chevron">&#9654;</span> Show Code</button>
    <div class="pg-code-block"><button class="pg-code-copy" onclick="copyPgCode(this)">Copy</button><pre>&lt;!-- Trigger a toast from a button --&gt;
&lt;button class="sui-btn sui-btn-primary"
  onclick="SoftUI.toast({ title: 'Notification', message: 'This is a default toast message.' })"&gt;
  Show Toast
&lt;/button&gt;

&lt;!-- Or call from JavaScript --&gt;
&lt;script&gt;
  SoftUI.toast({
    title: 'Notification',
    message: 'This is a default toast message.'
  });

  // Persistent toast (no auto-dismiss)
  SoftUI.toast({
    title: 'No auto-close',
    message: 'This toast stays until you dismiss it.',
    duration: 0
  });
&lt;/script&gt;</pre></div>
  </div>
</div>

<!-- Variants -->
<div class="pg-section" id="section-2">
  <h3 class="pg-section-title">Variants</h3>
  <div class="pg-section-row" style="gap:12px;flex-wrap:wrap;">
    <button class="sui-btn sui-btn-success" onclick="SoftUI.toast({ title: 'Success', message: 'Your changes have been saved.', variant: 'success' })">Success</button>
    <button class="sui-btn sui-btn-danger" onclick="SoftUI.toast({ title: 'Error', message: 'Something went wrong. Please try again.', variant: 'danger' })">Danger</button>
    <button class="sui-btn sui-btn-warning" onclick="SoftUI.toast({ title: 'Warning', message: 'Your session will expire in 5 minutes.', variant: 'warning' })">Warning</button>
    <button class="sui-btn sui-btn-info" onclick="SoftUI.toast({ title: 'Info', message: 'A new version is available.', variant: 'info' })">Info</button>
  </div>
  <div class="pg-code-wrap">
    <button class="pg-code-toggle" onclick="toggleGalleryCode(this)"><span class="chevron">&#9654;</span> Show Code</button>
    <div class="pg-code-block"><button class="pg-code-copy" onclick="copyPgCode(this)">Copy</button><pre>SoftUI.toast({
  title: 'Success',
  message: 'Your changes have been saved.',
  variant: 'success'
});

SoftUI.toast({
  title: 'Error',
  message: 'Something went wrong.',
  variant: 'danger'
});

SoftUI.toast({
  title: 'Warning',
  message: 'Your session will expire soon.',
  variant: 'warning'
});

SoftUI.toast({
  title: 'Info',
  message: 'A new version is available.',
  variant: 'info'
});</pre></div>
  </div>
</div>

<!-- Positions -->
<div class="pg-section" id="section-3">
  <h3 class="pg-section-title">Positions</h3>
  <div class="pg-section-row" style="gap:12px;flex-wrap:wrap;">
    <button class="sui-btn" onclick="SoftUI.toast({ title: 'Top Right', message: 'Default position.', position: 'tr' })">Top Right</button>
    <button class="sui-btn" onclick="SoftUI.toast({ title: 'Top Left', message: 'Slides in from the left.', position: 'tl' })">Top Left</button>
    <button class="sui-btn" onclick="SoftUI.toast({ title: 'Bottom Right', message: 'Bottom right corner.', position: 'br' })">Bottom Right</button>
    <button class="sui-btn" onclick="SoftUI.toast({ title: 'Bottom Left', message: 'Bottom left corner.', position: 'bl' })">Bottom Left</button>
    <button class="sui-btn" onclick="SoftUI.toast({ title: 'Top Center', message: 'Centered at the top.', position: 'tc' })">Top Center</button>
    <button class="sui-btn" onclick="SoftUI.toast({ title: 'Bottom Center', message: 'Centered at the bottom.', position: 'bc' })">Bottom Center</button>
  </div>
  <div class="pg-code-wrap">
    <button class="pg-code-toggle" onclick="toggleGalleryCode(this)"><span class="chevron">&#9654;</span> Show Code</button>
    <div class="pg-code-block"><button class="pg-code-copy" onclick="copyPgCode(this)">Copy</button><pre>// Position options: 'tr', 'tl', 'br', 'bl', 'tc', 'bc'
SoftUI.toast({
  title: 'Top Left',
  message: 'Slides in from the left.',
  position: 'tl'
});

SoftUI.toast({
  title: 'Top Center',
  message: 'Centered at the top.',
  position: 'tc'
});

// Options:
// title    — bold heading text
// message  — body text
// variant  — 'success', 'danger', 'warning', 'info'
// duration — ms before auto-dismiss (default 4000, 0 = persistent)
// position — 'tr', 'tl', 'br', 'bl', 'tc', 'bc' (default 'tr')
// closable — show close button (default true)</pre></div>
  </div>
</div>
