<!-- Section 5 — Filterable -->
<div class="pg-section" id="section-5">
  <h3 class="pg-section-title">Filterable</h3>
  <p class="pg-section-desc">Add a <code>.sui-datatable-filter</code> select with <code>data-filter-attr</code> to filter rows by a data attribute. Works with search, sort, and pagination.</p>

  <div class="pg-section-row">
    <div class="sui-datatable">
      <div class="sui-datatable-toolbar">
        <div class="sui-datatable-search">
          <svg class="sui-datatable-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input type="text" placeholder="Search...">
        </div>
        <div class="sui-dropdown sui-datatable-filter" data-filter-attr="data-dept">
          <button class="sui-dropdown-toggle" data-sui-dropdown aria-expanded="false" aria-haspopup="true">
            <span class="sui-datatable-filter-label">All Departments</span>
          </button>
          <div class="sui-dropdown-menu" role="menu">
            <button class="sui-dropdown-item active" data-value="" role="menuitem">All Departments</button>
            <button class="sui-dropdown-item" data-value="engineering" role="menuitem">Engineering</button>
            <button class="sui-dropdown-item" data-value="design" role="menuitem">Design</button>
            <button class="sui-dropdown-item" data-value="marketing" role="menuitem">Marketing</button>
            <button class="sui-dropdown-item" data-value="sales" role="menuitem">Sales</button>
          </div>
        </div>
        <div class="sui-datatable-perpage">
          <span>Show</span>
