&lt;label class="sui-radio sui-radio-danger"&gt;&lt;input type="radio" name="demo-radio-color2" checked&gt;&lt;span class="sui-radio-mark"&gt;&lt;/span&gt;Danger&lt;/label&gt;</pre></div>
