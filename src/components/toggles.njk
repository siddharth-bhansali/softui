<script>
document.addEventListener('DOMContentLoaded', function() {
  // Set indeterminate state on checkboxes with .indeterminate class
  document.querySelectorAll('input.indeterminate').forEach(function(el) {
    el.indeterminate = true;
  });

  const config = {
    defaults: { type: 'Toggle', color: 'Primary', size: 'Default', disabled: false },
    controls: [
      { key: 'type', label: 'Type', type: 'radio', options: ['Toggle', 'Checkbox', 'Radio'] },
      { key: 'color', label: 'Color', type: 'radio', options: ['Default', 'Primary', 'Success', 'Danger'] },
      { key: 'size', label: 'Size', type: 'radio', options: ['Small', 'Default', 'Large'] },
      { key: 'disabled', label: 'Disabled', type: 'toggle' },
    ],
    render(opts) {
      const c = opts.color.toLowerCase();
      const dis = opts.disabled ? ' disabled' : '';

      if (opts.type === 'Toggle') {
        let cls = 'sui-toggle';
        if (c !== 'default') cls += ' sui-toggle-' + c;
        if (opts.size === 'Small') cls += ' sui-toggle-sm';
        else if (opts.size === 'Large') cls += ' sui-toggle-lg';
        return '<label class="' + cls + '">\n  <input type="checkbox" checked' + dis + '>\n  <span class="sui-toggle-slider"></span>\n</label>';
      }

      if (opts.type === 'Checkbox') {
        let cls = 'sui-checkbox';
        if (c !== 'default') cls += ' sui-checkbox-' + c;
        return '<label class="' + cls + '">\n  <input type="checkbox" checked' + dis + '>\n  <span class="sui-check-mark"></span>\n  Checked\n</label>';
      }

      if (opts.type === 'Radio') {
        let cls = 'sui-radio';
        if (c !== 'default') cls += ' sui-radio-' + c;
        return '<label class="' + cls + '">\n  <input type="radio" name="pg-radio" checked' + dis + '>\n  <span class="sui-radio-mark"></span>\n  Option A\n</label>\n\n<label class="' + cls + '">\n  <input type="radio" name="pg-radio"' + dis + '>\n  <span class="sui-radio-mark"></span>\n  Option B\n</label>';
      }

      return '';
    }
  };

  function renderControls() {
    let html = '<div class="pg-controls-title">Customize</div>';
    config.controls.forEach(ctrl => {
      if (ctrl.type === 'radio') {
        html += '<div class="pg-control-group"><label class="pg-control-label">' + ctrl.label + '</label>';
        ctrl.options.forEach(opt => {
          const checked = opt === config.defaults[ctrl.key] ? ' checked' : '';
          html += '<label class="sui-radio"><input type="radio" name="ctrl-' + ctrl.key + '" value="' + opt + '"' + checked + ' onchange="updatePreview()"><span class="sui-radio-mark"></span>' + opt + '</label>';
        });
        html += '</div>';
      } else if (ctrl.type === 'toggle') {
        const checked = config.defaults[ctrl.key] ? ' checked' : '';
        html += '<div class="pg-control-group"><div class="pg-control-row"><label class="pg-control-label">' + ctrl.label + '</label><label class="sui-toggle sui-toggle-sm sui-toggle-primary"><input type="checkbox" data-control="' + ctrl.key + '"' + checked + ' onchange="updatePreview()"><span class="sui-toggle-slider"></span></label></div></div>';
      }
    });
    document.getElementById('pgControlsContent').innerHTML = html;
  }

  window.updatePreview = function() {
    const opts = {};
    config.controls.forEach(ctrl => {
      if (ctrl.type === 'radio') {
        const el = document.querySelector('input[name="ctrl-' + ctrl.key + '"]:checked');
        opts[ctrl.key] = el ? el.value : config.defaults[ctrl.key];
      } else if (ctrl.type === 'toggle') {
        const el = document.querySelector('[data-control="' + ctrl.key + '"]');
        opts[ctrl.key] = el ? el.checked : config.defaults[ctrl.key];
      }
    });
    const code = config.render(opts);
    document.getElementById('pgPreview').innerHTML = code;
    document.getElementById('pgCode').textContent = code;
  };

  renderControls();
  updatePreview();
});
</script>
