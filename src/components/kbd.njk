  <div class="pg-section-row" style="display:flex;flex-direction:column;gap:20px;align-items:flex-start;">
    <p style="font-size:14px;color:var(--sui-text);margin:0;">Press <kbd class="sui-kbd sui-kbd-sm">Esc</kbd> to close the dialog.</p>
    <p style="font-size:14px;color:var(--sui-text);margin:0;">Save your work with <span class="sui-kbd-group"><kbd class="sui-kbd sui-kbd-sm">Ctrl</kbd><span class="sui-kbd-separator">+</span><kbd class="sui-kbd sui-kbd-sm">S</kbd></span></p>
    <div style="display:flex;align-items:center;justify-content:space-between;gap:40px;padding:10px 16px;border-radius:var(--sui-radius-xs);background:var(--sui-bg);box-shadow:var(--sui-shadow-raised-sm);font-size:14px;color:var(--sui-text);">
      <span>Search</span>
      <span class="sui-kbd-group"><kbd class="sui-kbd sui-kbd-xs">&#8984;</kbd><kbd class="sui-kbd sui-kbd-xs">K</kbd></span>
    </div>
    <div style="display:flex;flex-direction:column;gap:2px;width:220px;">
      <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;border-radius:var(--sui-radius-xs);font-size:13px;color:var(--sui-text);">
        <span>Undo</span>
        <span class="sui-kbd-group"><kbd class="sui-kbd sui-kbd-xs">&#8984;</kbd><kbd class="sui-kbd sui-kbd-xs">Z</kbd></span>
      </div>
      <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;border-radius:var(--sui-radius-xs);font-size:13px;color:var(--sui-text);">
        <span>Redo</span>
        <span class="sui-kbd-group"><kbd class="sui-kbd sui-kbd-xs">&#8984;</kbd><kbd class="sui-kbd sui-kbd-xs">&#8679;</kbd><kbd class="sui-kbd sui-kbd-xs">Z</kbd></span>
      </div>
      <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;border-radius:var(--sui-radius-xs);font-size:13px;color:var(--sui-text);">
        <span>Copy</span>
        <span class="sui-kbd-group"><kbd class="sui-kbd sui-kbd-xs">&#8984;</kbd><kbd class="sui-kbd sui-kbd-xs">C</kbd></span>
      </div>
      <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;border-radius:var(--sui-radius-xs);font-size:13px;color:var(--sui-text);">
        <span>Paste</span>
        <span class="sui-kbd-group"><kbd class="sui-kbd sui-kbd-xs">&#8984;</kbd><kbd class="sui-kbd sui-kbd-xs">V</kbd></span>
      </div>
    </div>
  </div>
  <div class="pg-code-wrap">
