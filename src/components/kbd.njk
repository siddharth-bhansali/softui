    <div style="display:flex;align-items:center;gap:8px;">
      <span style="font-size:12px;color:var(--sui-text-muted);width:32px;">md</span>
      <kbd class="sui-kbd">Ctrl</kbd>
      <kbd class="sui-kbd">S</kbd>
    </div>
    <div style="display:flex;align-items:center;gap:8px;">
      <span style="font-size:12px;color:var(--sui-text-muted);width:32px;">lg</span>
