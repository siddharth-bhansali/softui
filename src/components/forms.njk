            <span class="sui-swap-on"><svg viewBox="0 0 24 24"><path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg></span>
            <span class="sui-swap-off"><svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></span>
          </button>
        </div>
        <div class="sui-password-rules" id="demo-pw-rules" style="margin-top:6px;">
          <div class="sui-password-rule" id="demo-rule-len"><svg viewBox="0 0 24 24" style="width:12px;height:12px;stroke:currentColor;fill:none;stroke-width:2;"><circle cx="12" cy="12" r="10"/></svg> 8–20 characters</div>
          <div class="sui-password-rule" id="demo-rule-upper"><svg viewBox="0 0 24 24" style="width:12px;height:12px;stroke:currentColor;fill:none;stroke-width:2;"><circle cx="12" cy="12" r="10"/></svg> One uppercase letter</div>
          <div class="sui-password-rule" id="demo-rule-num"><svg viewBox="0 0 24 24" style="width:12px;height:12px;stroke:currentColor;fill:none;stroke-width:2;"><circle cx="12" cy="12" r="10"/></svg> One number</div>
          <div class="sui-password-rule" id="demo-rule-special"><svg viewBox="0 0 24 24" style="width:12px;height:12px;stroke:currentColor;fill:none;stroke-width:2;"><circle cx="12" cy="12" r="10"/></svg> One special character</div>
        </div>
      </div>
      <div class="sui-form-group">
        <label class="sui-label">Confirm Password</label>
        <div class="sui-password-input">
          <input type="password" class="sui-input" id="demo-pw-confirm" placeholder="Confirm password" autocomplete="new-password" oninput="demoValidatePw()">
          <button type="button" class="sui-password-toggle sui-swap sui-swap-fade" aria-label="Toggle password visibility">
            <span class="sui-swap-on"><svg viewBox="0 0 24 24"><path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg></span>
            <span class="sui-swap-off"><svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></span>
          </button>
        </div>
        <span class="sui-hint sui-hint-error" id="demo-pw-match" style="display:none;">Passwords do not match.</span>
        <span class="sui-hint sui-hint-success" id="demo-pw-ok" style="display:none;">Passwords match!</span>
      </div>
    </div>
  </div>
  <script>
    function demoValidatePw() {
      var pw = document.getElementById('demo-pw');
      var confirm = document.getElementById('demo-pw-confirm');
      var val = pw.value;
      // Rules
      var rules = [
        { id: 'demo-rule-len', test: val.length >= 8 && val.length <= 20 },
        { id: 'demo-rule-upper', test: /[A-Z]/.test(val) },
        { id: 'demo-rule-num', test: /[0-9]/.test(val) },
        { id: 'demo-rule-special', test: /[^A-Za-z0-9]/.test(val) }
      ];
      var checkSvg = '<svg viewBox="0 0 24 24" style="width:12px;height:12px;stroke:currentColor;fill:none;stroke-width:2;"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>';
      var circleSvg = '<svg viewBox="0 0 24 24" style="width:12px;height:12px;stroke:currentColor;fill:none;stroke-width:2;"><circle cx="12" cy="12" r="10"/></svg>';
      rules.forEach(function(r) {
        var el = document.getElementById(r.id);
        var text = el.textContent.trim();
        if (r.test) {
          el.classList.add('valid');
          el.innerHTML = checkSvg + ' ' + text;
        } else {
          el.classList.remove('valid');
          el.innerHTML = circleSvg + ' ' + text;
        }
      });
      // Confirm match
      var matchErr = document.getElementById('demo-pw-match');
      var matchOk = document.getElementById('demo-pw-ok');
      if (confirm.value.length > 0) {
        if (confirm.value === val) {
          matchErr.style.display = 'none';
          matchOk.style.display = '';
          confirm.classList.remove('sui-input-error');
          confirm.classList.add('sui-input-success');
        } else {
          matchErr.style.display = '';
          matchOk.style.display = 'none';
          confirm.classList.add('sui-input-error');
          confirm.classList.remove('sui-input-success');
        }
      } else {
        matchErr.style.display = 'none';
        matchOk.style.display = 'none';
        confirm.classList.remove('sui-input-error', 'sui-input-success');
      }
    }
  </script>
  <div class="pg-code-wrap">
    <button class="pg-code-toggle" onclick="toggleGalleryCode(this)"><span class="chevron">&#9654;</span> Show Code</button>
