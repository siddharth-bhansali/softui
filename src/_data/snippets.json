    {
      "id": "accordion",
      "label": "Accordion",
      "code": "<div class=\"sui-accordion\">\n  <div class=\"sui-accordion-item active\">\n    <button type=\"button\" class=\"sui-accordion-header\">What is SoftUI?</button>\n    <div class=\"sui-accordion-body\">\n      <div class=\"sui-accordion-body-inner\">\n        SoftUI is a neumorphic CSS component library with soft shadows and rounded surfaces.\n      </div>\n    </div>\n  </div>\n  <div class=\"sui-accordion-item\">\n    <button type=\"button\" class=\"sui-accordion-header\">Do I need JavaScript?</button>\n    <div class=\"sui-accordion-body\">\n      <div class=\"sui-accordion-body-inner\">\n        The accordion requires softui.js for expand/collapse behavior.\n      </div>\n    </div>\n  </div>\n  <div class=\"sui-accordion-item\">\n    <button type=\"button\" class=\"sui-accordion-header\">Can I customize the styles?</button>\n    <div class=\"sui-accordion-body\">\n      <div class=\"sui-accordion-body-inner\">\n        Yes. Override CSS custom properties on :root to theme everything.\n      </div>\n    </div>\n  </div>\n</div>"
    },
    {
      "id": "tabs",
      "label": "Tabs",
      "code": "<div class=\"sui-tabs\">\n  <div class=\"sui-tab-list\">\n    <button class=\"sui-tab active\" data-sui-tab=\"tab-profile\">Profile</button>\n    <button class=\"sui-tab\" data-sui-tab=\"tab-settings\">Settings</button>\n    <button class=\"sui-tab\" data-sui-tab=\"tab-billing\">Billing</button>\n  </div>\n  <div class=\"sui-tab-panel active\" id=\"tab-profile\">\n    <div class=\"sui-card\"><div class=\"sui-card-body\">Profile content goes here.</div></div>\n  </div>\n  <div class=\"sui-tab-panel\" id=\"tab-settings\">\n    <div class=\"sui-card\"><div class=\"sui-card-body\">Settings content goes here.</div></div>\n  </div>\n  <div class=\"sui-tab-panel\" id=\"tab-billing\">\n    <div class=\"sui-card\"><div class=\"sui-card-body\">Billing content goes here.</div></div>\n  </div>\n</div>"
    },
    {
      "id": "modal",
      "label": "Modal",
      "code": "<div class=\"sui-modal-backdrop\" id=\"myModal\">\n  <div class=\"sui-modal\">\n    <div class=\"sui-modal-header\">\n      <h3>Modal Title</h3>\n      <button class=\"sui-modal-close\" aria-label=\"Close\"></button>\n    </div>\n    <div class=\"sui-modal-body\">\n      <p>This is a neumorphic modal dialog.</p>\n    </div>\n    <div class=\"sui-modal-footer\">\n      <button class=\"sui-btn sui-btn-sm\" onclick=\"SoftUI.modal('#myModal').close()\">Cancel</button>\n      <button class=\"sui-btn sui-btn-primary sui-btn-sm\">Confirm</button>\n    </div>\n  </div>\n</div>\n\n<button class=\"sui-btn sui-btn-primary\" onclick=\"SoftUI.modal('#myModal').open()\">Open Modal</button>"
    },
