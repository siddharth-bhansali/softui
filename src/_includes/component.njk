---
layout: base.njk
---
<div class="docs-component">

  <!-- Left Sidebar -->
  <aside class="docs-pg-sidebar">
    {% set groups = [
      { key: "forms", label: "Forms" },
      { key: "general", label: "General" },
      { key: "dataDisplay", label: "Data Display" },
      { key: "feedback", label: "Feedback" },
      { key: "navigation", label: "Navigation" },
      { key: "overlays", label: "Overlays" },
      { key: "layout", label: "Layout" },
      { key: "media", label: "Media" },
      { key: "utilities", label: "Utilities" }
    ] %}
    {%- for group in groups %}
    <div class="pg-sidebar-cat">{{ group.label }}</div>
    {%- for item in nav[group.key] %}
    <a class="pg-sidebar-link{% if item.id == componentId %} active{% endif %}" href="{{ item.url }}">{{ item.name }}</a>
    {%- endfor %}
    {%- endfor %}
  </aside>

  <!-- Main Content -->
  <div class="docs-pg-main">
    <nav class="sui-breadcrumb sui-breadcrumb-flat" style="font-size:13px;padding:4px 0;margin-bottom:4px;margin-left:-8px;">
      <span class="sui-breadcrumb-item"><a href="/">Home</a></span>
      <span class="sui-breadcrumb-item active"><span>{{ title }}</span></span>
    </nav>
    <h1 class="docs-pg-title">{{ title }}</h1>
    <p class="docs-pg-desc">{{ description }}</p>
    {% if requiresJs %}
    <div class="docs-js-note">
      <svg viewBox="0 0 24 24" style="width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0;"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
      <span>{% if partialJs %}Some sections on this page require{% else %}This component requires{% endif %} <a href="/getting-started/#javascript">softui.js</a> for interactive behavior.</span>
    </div>
    {% endif %}

    {{ content | safe }}
  </div>

  <!-- Right Panel -->
  <aside class="docs-pg-controls">
    <div class="pg-toc-title">On This Page</div>
    {%- for section in toc %}
    <a class="pg-toc-link" href="#section-{{ loop.index }}">{{ section }}</a>
    {%- endfor %}
  </aside>

</div>
