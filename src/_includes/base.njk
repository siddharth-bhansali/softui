<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — SoftUI</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/softui.css">
  <link rel="stylesheet" href="/css/docs.css">
  <script src="/softui.js"></script>
</head>
<body>

  <!-- Top Navbar -->
  <nav class="docs-topbar">
    <a class="docs-topbar-brand" href="/">Soft<span>UI</span></a>
    <div class="docs-topbar-nav">
      <a href="/"{% if page.url == "/" %} class="active"{% endif %}>All</a>
      <a href="/?filter=forms"{% if filter == "forms" %} class="active"{% endif %}>Forms</a>
      <a href="/?filter=components"{% if filter == "components" %} class="active"{% endif %}>Components</a>
      <a href="/?filter=utilities"{% if filter == "utilities" %} class="active"{% endif %}>Utilities</a>
    </div>
    <div class="docs-topbar-actions">
      <button class="docs-theme-toggle" onclick="toggleTheme()">
        <span class="theme-icon">&#9790;</span>
      </button>
      <button class="docs-hamburger" onclick="toggleMobileNav()" aria-label="Toggle navigation">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- Mobile Nav Drawer -->
  <div class="docs-mobile-overlay" onclick="toggleMobileNav()"></div>
  <nav class="docs-mobile-drawer">
    <div class="mobile-drawer-header">
      <span class="docs-topbar-brand">Soft<span>UI</span></span>
      <button class="docs-mobile-close" onclick="toggleMobileNav()" aria-label="Close navigation">&times;</button>
    </div>
    <div class="mobile-drawer-links">
      <a href="/">Home</a>
    </div>
    <div class="mobile-drawer-cat">Forms</div>
    {%- for item in nav.forms %}
    <a class="mobile-drawer-link{% if item.id == componentId %} active{% endif %}" href="{{ item.url }}">{{ item.name }}</a>
    {%- endfor %}
    <div class="mobile-drawer-cat">Components</div>
    {%- for item in nav.components %}
    <a class="mobile-drawer-link{% if item.id == componentId %} active{% endif %}" href="{{ item.url }}">{{ item.name }}</a>
    {%- endfor %}
    <div class="mobile-drawer-cat">Utilities</div>
    {%- for item in nav.utilities %}
    <a class="mobile-drawer-link{% if item.id == componentId %} active{% endif %}" href="{{ item.url }}">{{ item.name }}</a>
    {%- endfor %}
  </nav>

  {{ content | safe }}

  <!-- Modal Instances (for demos) -->
  <div class="sui-modal-backdrop" id="demoModal" role="dialog" aria-modal="true">
    <div class="sui-modal">
      <div class="sui-modal-header"><h3>Modal Title</h3><button class="sui-modal-close" aria-label="Close"></button></div>
      <div class="sui-modal-body"><p>This is a neumorphic modal dialog. It features backdrop blur, smooth animations, and focus trap. Press Escape or click outside to close.</p></div>
      <div class="sui-modal-footer"><button class="sui-btn sui-btn-sm" onclick="SoftUI.modal('#demoModal').close()">Cancel</button><button class="sui-btn sui-btn-primary sui-btn-sm">Confirm</button></div>
    </div>
  </div>
  <div class="sui-modal-backdrop" id="demoModalSm" role="dialog" aria-modal="true">
    <div class="sui-modal sui-modal-sm">
      <div class="sui-modal-header"><h3>Session Timeout</h3><button class="sui-modal-close" aria-label="Close"></button></div>
      <div class="sui-modal-body"><p>Your session will expire in 5 minutes. Would you like to stay signed in?</p></div>
      <div class="sui-modal-footer"><button class="sui-btn sui-btn-sm" onclick="SoftUI.modal('#demoModalSm').close()">Sign Out</button><button class="sui-btn sui-btn-primary sui-btn-sm" onclick="SoftUI.modal('#demoModalSm').close()">Stay Signed In</button></div>
    </div>
  </div>
  <div class="sui-modal-backdrop sui-modal-static" id="demoModalAlert" role="alertdialog" aria-modal="true" aria-labelledby="alertDialogTitle" aria-describedby="alertDialogDesc">
    <div class="sui-modal sui-modal-sm">
      <div class="sui-modal-header"><h3 id="alertDialogTitle">Delete this item?</h3></div>
      <div class="sui-modal-body"><p id="alertDialogDesc">This action cannot be undone. This will permanently delete the item and remove all associated data.</p></div>
      <div class="sui-modal-footer"><button class="sui-btn sui-btn-sm" onclick="SoftUI.modal('#demoModalAlert').close()">Cancel</button><button class="sui-btn sui-btn-danger sui-btn-sm" onclick="SoftUI.modal('#demoModalAlert').close()">Delete</button></div>
    </div>
  </div>
  <div class="sui-modal-backdrop" id="demoModalLg" role="dialog" aria-modal="true">
    <div class="sui-modal sui-modal-lg">
      <div class="sui-modal-header"><h3>Create Account</h3><button class="sui-modal-close" aria-label="Close"></button></div>
      <div class="sui-modal-body">
        <div class="sui-form-group"><label class="sui-label">Full Name</label><input type="text" class="sui-input" placeholder="John Doe"></div>
        <div class="sui-form-group"><label class="sui-label">Email Address</label><input type="email" class="sui-input" placeholder="john@example.com"></div>
        <div class="sui-form-group"><label class="sui-label">Message</label><textarea class="sui-input sui-textarea" placeholder="Tell us about yourself..."></textarea></div>
      </div>
      <div class="sui-modal-footer"><button class="sui-btn sui-btn-sm" onclick="SoftUI.modal('#demoModalLg').close()">Cancel</button><button class="sui-btn sui-btn-primary sui-btn-sm">Create Account</button></div>
    </div>
  </div>
  <div class="sui-modal-backdrop" id="demoModalFs" role="dialog" aria-modal="true">
    <div class="sui-modal sui-modal-fullscreen">
      <div class="sui-modal-header"><h3>Fullscreen Modal</h3><button class="sui-modal-close" aria-label="Close"></button></div>
      <div class="sui-modal-body"><p>This modal takes up the entire viewport. Useful for immersive content, editors, or media viewers.</p><p>Press Escape or click the close button to dismiss.</p></div>
      <div class="sui-modal-footer"><button class="sui-btn sui-btn-sm" onclick="SoftUI.modal('#demoModalFs').close()">Close</button></div>
    </div>
  </div>
  <div class="sui-modal-backdrop" id="demoModalScroll" role="dialog" aria-modal="true">
    <div class="sui-modal sui-modal-scrollable">
      <div class="sui-modal-header"><h3>Terms of Service</h3><button class="sui-modal-close" aria-label="Close"></button></div>
      <div class="sui-modal-body">
