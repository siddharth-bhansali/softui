      <div class="sui-modal-footer"><button class="sui-btn sui-btn-sm" onclick="SoftUI.modal('#demoModalScroll').close()">Decline</button><button class="sui-btn sui-btn-primary sui-btn-sm">Accept</button></div>
    </div>
  </div>
  <div class="sui-modal-backdrop sui-modal-static" id="demoModalStatic" role="dialog" aria-modal="true">
    <div class="sui-modal">
      <div class="sui-modal-header"><h3>Static Backdrop</h3><button class="sui-modal-close" aria-label="Close"></button></div>
      <div class="sui-modal-body"><p>Clicking outside this modal won't close it. Instead, the modal will shake to indicate it requires explicit action. Use the close button or press Escape to dismiss.</p></div>
      <div class="sui-modal-footer"><button class="sui-btn sui-btn-sm" onclick="SoftUI.modal('#demoModalStatic').close()">Cancel</button><button class="sui-btn sui-btn-primary sui-btn-sm">Understood</button></div>
    </div>
  </div>

  <!-- Sheet demos -->
  <div class="sui-sheet-backdrop" id="demoSheet" role="dialog" aria-modal="true" aria-label="Default Sheet">
    <div class="sui-sheet sui-sheet-right">
      <div class="sui-sheet-header"><h3>Sheet Title</h3><button class="sui-sheet-close" aria-label="Close"></button></div>
      <div class="sui-sheet-body"><p>This is a default right-side sheet. It slides in from the right edge of the screen with a blurred backdrop.</p><p>Sheets are great for navigation menus, settings panels, detail views, and forms that don't need to interrupt the main content flow.</p></div>
      <div class="sui-sheet-footer"><button class="sui-btn sui-btn-sm" onclick="SoftUI.sheet('#demoSheet').close()">Cancel</button><button class="sui-btn sui-btn-primary sui-btn-sm">Save</button></div>
    </div>
  </div>
  <div class="sui-sheet-backdrop" id="demoSheetLeft" role="dialog" aria-modal="true" aria-label="Left Sheet">
    <div class="sui-sheet sui-sheet-left">
      <div class="sui-sheet-header"><h3>Navigation</h3><button class="sui-sheet-close" aria-label="Close"></button></div>
      <div class="sui-sheet-body" style="padding-top:8px;"><a href="#" style="display:block;padding:10px 0;color:var(--sui-text);text-decoration:none;border-bottom:1px solid var(--sui-bg-dark);">Dashboard</a><a href="#" style="display:block;padding:10px 0;color:var(--sui-text);text-decoration:none;border-bottom:1px solid var(--sui-bg-dark);">Analytics</a><a href="#" style="display:block;padding:10px 0;color:var(--sui-text);text-decoration:none;border-bottom:1px solid var(--sui-bg-dark);">Customers</a><a href="#" style="display:block;padding:10px 0;color:var(--sui-text);text-decoration:none;border-bottom:1px solid var(--sui-bg-dark);">Settings</a><a href="#" style="display:block;padding:10px 0;color:var(--sui-text);text-decoration:none;">Help</a></div>
    </div>
  </div>
  <div class="sui-sheet-backdrop" id="demoSheetTop" role="dialog" aria-modal="true" aria-label="Top Sheet">
    <div class="sui-sheet sui-sheet-top sui-sheet-sm">
      <div class="sui-sheet-header"><h3>Announcement</h3><button class="sui-sheet-close" aria-label="Close"></button></div>
      <div class="sui-sheet-body"><p>This sheet slides down from the top. Great for announcements, notification panels, or search interfaces.</p></div>
    </div>
  </div>
  <div class="sui-sheet-backdrop" id="demoSheetBottom" role="dialog" aria-modal="true" aria-label="Bottom Sheet">
    <div class="sui-sheet sui-sheet-bottom sui-sheet-sm">
      <div class="sui-sheet-header"><h3>Quick Actions</h3><button class="sui-sheet-close" aria-label="Close"></button></div>
      <div class="sui-sheet-body"><div style="display:flex;gap:10px;flex-wrap:wrap;"><button class="sui-btn sui-btn-primary sui-btn-sm">Share</button><button class="sui-btn sui-btn-success sui-btn-sm">Download</button><button class="sui-btn sui-btn-info sui-btn-sm">Print</button><button class="sui-btn sui-btn-danger sui-btn-sm">Delete</button></div></div>
    </div>
  </div>
  <div class="sui-sheet-backdrop" id="demoSheetSm" role="dialog" aria-modal="true" aria-label="Small Sheet">
    <div class="sui-sheet sui-sheet-right sui-sheet-sm">
      <div class="sui-sheet-header"><h3>Small Sheet</h3><button class="sui-sheet-close" aria-label="Close"></button></div>
      <div class="sui-sheet-body"><p>This is a small (280px) right-side sheet.</p></div>
      <div class="sui-sheet-footer"><button class="sui-btn sui-btn-sm" onclick="SoftUI.sheet('#demoSheetSm').close()">Close</button></div>
    </div>
  </div>
  <div class="sui-sheet-backdrop" id="demoSheetLg" role="dialog" aria-modal="true" aria-label="Large Sheet">
    <div class="sui-sheet sui-sheet-right sui-sheet-lg">
      <div class="sui-sheet-header"><h3>Large Sheet</h3><button class="sui-sheet-close" aria-label="Close"></button></div>
      <div class="sui-sheet-body"><p>This is a large (480px) right-side sheet. Great for forms, detail views, or complex content.</p></div>
      <div class="sui-sheet-footer"><button class="sui-btn sui-btn-sm" onclick="SoftUI.sheet('#demoSheetLg').close()">Cancel</button><button class="sui-btn sui-btn-primary sui-btn-sm">Save Changes</button></div>
    </div>
  </div>
  <div class="sui-sheet-backdrop" id="demoSheetForm" role="dialog" aria-modal="true" aria-label="Edit Profile">
    <div class="sui-sheet sui-sheet-right sui-sheet-lg">
      <div class="sui-sheet-header"><h3>Edit Profile</h3><button class="sui-sheet-close" aria-label="Close"></button></div>
      <div class="sui-sheet-body"><div class="sui-form-group" style="margin-bottom:16px;"><label class="sui-label">Full Name</label><input type="text" class="sui-input" placeholder="John Doe"></div><div class="sui-form-group" style="margin-bottom:16px;"><label class="sui-label">Email</label><input type="email" class="sui-input" placeholder="john@example.com"></div><div class="sui-form-group" style="margin-bottom:16px;"><label class="sui-label">Bio</label><textarea class="sui-input sui-textarea" rows="4" placeholder="Tell us about yourself..."></textarea></div><label class="sui-checkbox"><input type="checkbox" checked><span class="sui-check-mark"></span>Make profile public</label></div>
      <div class="sui-sheet-footer"><button class="sui-btn sui-btn-sm" onclick="SoftUI.sheet('#demoSheetForm').close()">Cancel</button><button class="sui-btn sui-btn-primary sui-btn-sm">Update Profile</button></div>
    </div>
  </div>
  <div class="sui-sheet-backdrop sui-sheet-static" id="demoSheetStatic" role="dialog" aria-modal="true" aria-label="Static Sheet">
    <div class="sui-sheet sui-sheet-right">
      <div class="sui-sheet-header"><h3>Static Backdrop</h3><button class="sui-sheet-close" aria-label="Close"></button></div>
      <div class="sui-sheet-body"><p>Clicking outside this sheet won't close it. The sheet will shake to indicate it requires explicit action. Use the close button or press Escape.</p></div>
      <div class="sui-sheet-footer"><button class="sui-btn sui-btn-sm" onclick="SoftUI.sheet('#demoSheetStatic').close()">Close</button></div>
    </div>
  </div>

  <script>
    // Mobile nav
    function toggleMobileNav() {
      const drawer = document.querySelector('.docs-mobile-drawer');
      const opening = !drawer.classList.contains('open');
      drawer.classList.toggle('open');
      document.querySelector('.docs-mobile-overlay').classList.toggle('open');
      document.body.classList.toggle('mobile-nav-open');
      if (opening) {
        const active = drawer.querySelector('.mobile-drawer-link.active');
        if (active) {
          active.scrollIntoView({ block: 'center', behavior: 'instant' });
        }
      }
    }
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && document.querySelector('.docs-mobile-drawer.open')) {
        toggleMobileNav();
      }
    });

    // Theme
    function toggleTheme() {
      const html = document.documentElement;
      const isDark = html.getAttribute('data-theme') === 'dark';
      html.setAttribute('data-theme', isDark ? 'light' : 'dark');
      document.querySelector('.theme-icon').textContent = isDark ? '\u263E' : '\u2600';
      localStorage.setItem('sui-theme', isDark ? 'light' : 'dark');
    }
    (function() {
      const saved = localStorage.getItem('sui-theme');
      if (saved === 'dark') {
        document.documentElement.setAttribute('data-theme', 'dark');
        document.querySelector('.theme-icon').textContent = '\u2600';
      }
    })();

    // Scroll sidebar to active item on page load
    (function() {
      const sidebar = document.querySelector('.docs-pg-sidebar');
      if (sidebar) {
        const active = sidebar.querySelector('.pg-sidebar-link.active');
        if (active) {
          active.scrollIntoView({ block: 'center', behavior: 'instant' });
        }
      }
    })();

    // Copy code
    function copyPgCode(btn) {
      const pre = btn.parentElement.querySelector('pre');
      navigator.clipboard.writeText(pre.textContent).then(() => {
        btn.textContent = 'Copied!';
        setTimeout(() => btn.textContent = 'Copy', 1500);
      });
    }

    // Toggle code blocks
    function toggleGalleryCode(btn) {
      const block = btn.nextElementSibling;
      const isOpen = block.classList.toggle('open');
      btn.classList.toggle('open', isOpen);
    }
  </script>
</body>
</html>
