  <p style="font-size:13px;color:var(--sui-text-light);margin-bottom:16px;">Add <code>sui-aspect sui-aspect-video</code> for widescreen 16:9 ratio.</p>
  <div class="pg-section-row" style="align-items:flex-start;">
    <div class="sui-aspect sui-aspect-video" style="max-width:400px;border-radius:var(--sui-radius-sm);box-shadow:var(--sui-shadow-raised-sm);">
      <div style="display:flex;align-items:center;justify-content:center;background:{{ gradients[0] }};color:#fff;font-size:14px;font-weight:600;">16 : 9</div>
    </div>
  </div>
