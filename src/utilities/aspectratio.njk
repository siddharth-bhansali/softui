<!-- With Content -->
<div class="pg-section" id="section-7">
  <h3 class="pg-section-title">With Content</h3>
  <p style="font-size:13px;color:var(--sui-text-light);margin-bottom:16px;">Children are stretched to fill the container. Use <code>object-fit: cover</code> on images or flex alignment on content.</p>
  <div class="pg-section-row" style="display:flex;gap:16px;flex-wrap:wrap;align-items:flex-start;">
    <div class="sui-aspect sui-aspect-video" style="max-width:280px;border-radius:var(--sui-radius-sm);box-shadow:var(--sui-shadow-raised-sm);">
      <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;background:var(--sui-bg);padding:16px;">
        <div style="width:48px;height:48px;border-radius:50%;background:{{ gradients[0] }};"></div>
        <span style="font-size:14px;font-weight:600;color:var(--sui-text);">Video Player</span>
