<!-- Width -->
<div class="pg-section" id="section-1">
  <h3 class="pg-section-title">Width</h3>
  <div style="display:flex;flex-direction:column;gap:12px;">
    <div>
      <small style="display:block;margin-bottom:4px;color:var(--sui-text-muted);">sui-w-full (width: 100%)</small>
      <div class="sui-inset" style="padding:10px;border-radius:8px;">
        <div class="sui-w-full sui-raised" style="padding:10px 14px;border-radius:6px;text-align:center;">w-full</div>
      </div>
    </div>
    <div>
      <small style="display:block;margin-bottom:4px;color:var(--sui-text-muted);">sui-w-auto (width: auto)</small>
      <div class="sui-inset" style="padding:10px;border-radius:8px;">
        <div class="sui-w-auto sui-raised" style="padding:10px 14px;border-radius:6px;display:inline-block;">w-auto sizes to content</div>
      </div>
    </div>
    <div>
      <small style="display:block;margin-bottom:4px;color:var(--sui-text-muted);">sui-w-screen (width: 100vw)</small>
      <div class="sui-inset" style="padding:10px;border-radius:8px;">
        <div class="sui-raised" style="padding:10px 14px;border-radius:6px;text-align:center;">
          <code>sui-w-screen</code> — spans the full viewport width
        </div>
      </div>
    </div>
  </div>
  <div class="pg-code-wrap">
    <button class="pg-code-toggle" onclick="toggleGalleryCode(this)"><span class="chevron">&#9654;</span> Show Code</button>
    <div class="pg-code-block"><button class="pg-code-copy" onclick="copyPgCode(this)">Copy</button><pre>&lt;div class="sui-w-full"&gt;100% width&lt;/div&gt;
&lt;div class="sui-w-auto"&gt;Auto width (content-sized)&lt;/div&gt;
&lt;div class="sui-w-screen"&gt;100vw width&lt;/div&gt;
&lt;div class="sui-min-w-0"&gt;min-width: 0 (useful for flex truncation)&lt;/div&gt;</pre></div>
  </div>
</div>

