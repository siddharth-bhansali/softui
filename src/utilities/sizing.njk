&lt;div class="sui-max-w-none"&gt;max-width: none&lt;/div&gt;</pre></div>
  </div>
</div>

<!-- Height -->
<div class="pg-section" id="section-3">
  <h3 class="pg-section-title">Height</h3>
  <div style="display:flex;flex-direction:column;gap:12px;">
    <div>
      <small style="display:block;margin-bottom:4px;color:var(--sui-text-muted);">Height utilities inside a fixed-height container (200px)</small>
      <div class="sui-d-flex sui-gap-3 sui-inset" style="padding:10px;border-radius:8px;height:200px;">
        <div class="sui-h-full sui-raised" style="width:80px;border-radius:6px;display:flex;align-items:center;justify-content:center;text-align:center;font-size:0.8rem;">
          h-full<br>(100%)
        </div>
        <div class="sui-h-auto sui-raised" style="width:80px;border-radius:6px;display:flex;align-items:center;justify-content:center;text-align:center;padding:10px;font-size:0.8rem;">
          h-auto
        </div>
        <div class="sui-raised" style="width:80px;height:50%;border-radius:6px;display:flex;align-items:center;justify-content:center;text-align:center;font-size:0.8rem;">
          50%<br>(inline)
        </div>
      </div>
    </div>
    <div>
      <small style="display:block;margin-bottom:4px;color:var(--sui-text-muted);">Viewport-relative heights (shown as descriptions)</small>
      <div class="sui-d-flex sui-flex-wrap sui-gap-2" style="padding:0;">
        <div class="sui-raised" style="padding:12px 16px;border-radius:8px;">
          <code>sui-h-screen</code><br><small style="color:var(--sui-text-muted);">height: 100vh</small>
        </div>
        <div class="sui-raised" style="padding:12px 16px;border-radius:8px;">
          <code>sui-min-h-screen</code><br><small style="color:var(--sui-text-muted);">min-height: 100vh</small>
        </div>
        <div class="sui-raised" style="padding:12px 16px;border-radius:8px;">
          <code>sui-max-h-screen</code><br><small style="color:var(--sui-text-muted);">max-height: 100vh</small>
        </div>
        <div class="sui-raised" style="padding:12px 16px;border-radius:8px;">
          <code>sui-min-h-full</code><br><small style="color:var(--sui-text-muted);">min-height: 100%</small>
        </div>
        <div class="sui-raised" style="padding:12px 16px;border-radius:8px;">
          <code>sui-max-h-full</code><br><small style="color:var(--sui-text-muted);">max-height: 100%</small>
        </div>
        <div class="sui-raised" style="padding:12px 16px;border-radius:8px;">
          <code>sui-min-h-0</code><br><small style="color:var(--sui-text-muted);">min-height: 0</small>
        </div>
      </div>
    </div>
  </div>
  <div class="pg-code-wrap">
    <button class="pg-code-toggle" onclick="toggleGalleryCode(this)"><span class="chevron">&#9654;</span> Show Code</button>
    <div class="pg-code-block"><button class="pg-code-copy" onclick="copyPgCode(this)">Copy</button><pre>&lt;div class="sui-h-full"&gt;height: 100%&lt;/div&gt;
&lt;div class="sui-h-auto"&gt;height: auto&lt;/div&gt;
&lt;div class="sui-h-screen"&gt;height: 100vh&lt;/div&gt;
&lt;div class="sui-min-h-0"&gt;min-height: 0&lt;/div&gt;
&lt;div class="sui-min-h-full"&gt;min-height: 100%&lt;/div&gt;
&lt;div class="sui-min-h-screen"&gt;min-height: 100vh&lt;/div&gt;
&lt;div class="sui-max-h-full"&gt;max-height: 100%&lt;/div&gt;
&lt;div class="sui-max-h-screen"&gt;max-height: 100vh&lt;/div&gt;</pre></div>
  </div>
</div>
