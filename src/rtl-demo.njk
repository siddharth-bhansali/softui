      <div class="sui-form-group" style="margin-bottom:12px;">
        <label class="sui-label">البريد الإلكتروني</label>
        <input class="sui-input" type="email" placeholder="ahmed@example.com">
      </div>
      <div class="sui-form-group" style="margin-bottom:12px;">
        <label class="sui-label">كلمة المرور</label>
        <input class="sui-input" type="password" placeholder="أدخل كلمة المرور">
      </div>
      <div class="sui-form-group" style="margin-bottom:16px;">
        <label class="sui-label">الدولة</label>
        <div class="sui-styled-select" data-placeholder="اختر دولة">
          <button type="button" class="sui-styled-select-trigger">
            <span class="sui-styled-select-value sui-styled-select-placeholder">اختر دولة</span>
          </button>
          <div class="sui-styled-select-menu">
            <div class="sui-styled-select-option" data-value="sa">المملكة العربية السعودية</div>
            <div class="sui-styled-select-option" data-value="ae">الإمارات العربية المتحدة</div>
            <div class="sui-styled-select-option" data-value="eg">مصر</div>
            <div class="sui-styled-select-option" data-value="jo">الأردن</div>
          </div>
        </div>
      </div>
      <label class="sui-checkbox" style="margin-bottom:16px;">
        <input type="checkbox">
        <span class="sui-check-mark"></span>
        أوافق على الشروط والأحكام
      </label>
      <button class="sui-btn sui-btn-primary sui-btn-block">إنشاء حساب</button>
    </div>
  </section>

