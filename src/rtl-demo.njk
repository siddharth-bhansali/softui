  <!-- Form -->
  <section class="docs-getstarted-section" id="form">
    <h2>نموذج</h2>
    <div class="sui-card" style="padding:24px;max-width:500px;">
      <h4 style="margin:0 0 16px;">تسجيل حساب جديد</h4>
      <div class="sui-row sui-g-2" style="margin-bottom:12px;">
        <div class="sui-col-12 sui-col-sm-6">
          <div class="sui-form-group">
            <label class="sui-label">الاسم الأول</label>
            <input class="sui-input" type="text" placeholder="أحمد">
          </div>
        </div>
        <div class="sui-col-12 sui-col-sm-6">
          <div class="sui-form-group">
            <label class="sui-label">اسم العائلة</label>
            <input class="sui-input" type="text" placeholder="محمد">
          </div>
